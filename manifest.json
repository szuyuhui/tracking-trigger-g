{
  "manifest_version": 3,
  "name": "Tracking Trigger Monitor",
  "version": "1.0.0",
  "description": "Intercepts and displays tracking requests.",
  "icons": {
    "16": "assets/img/icon-16.png",
    "32": "assets/img/icon-32.png",
    "48": "assets/img/icon-48.png",
    "128": "assets/img/icon-128.png",
    "400": "assets/img/icon.png"
  },
  "permissions": [
    "sidePanel",
    "webRequest",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/js/content-isolated.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["assets/js/content-main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Tracking Monitor"
  }
}